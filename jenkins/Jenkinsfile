        // ---------------------------------------------------------------
        // APPROVAL GATE 3 — Monitoring stack (optional, infra changes rarely)
        // ---------------------------------------------------------------
        stage('Approval: Deploy Monitoring Stack') {
            when {
                branch 'main'
            }
            steps {
                timeout(time: 30, unit: 'MINUTES') {
                    input message: 'Apply/Update Prometheus + Grafana monitoring stack?',
                          ok: 'Yes, Deploy',
                          submitter: 'devops-team,team-lead'
                }
            }
        }

        stage('Deploy Monitoring Stack') {
            when {
                branch 'main'
            }
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'AWS-cred',
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    sh '''
                        helm repo add prometheus-community https://prometheus-community.github.io/helm-charts
                        helm repo update

                        helm upgrade --install monitoring prometheus-community/kube-prometheus-stack \
                            --namespace monitoring \
                            --create-namespace \
                            --set prometheus.prometheusSpec.scrapeInterval=15s \
                            --set grafana.adminPassword=admin123 \
                            --set grafana.service.type=LoadBalancer \
                            --wait --timeout 5m
                    '''
                }
            }
        }

        stage('Apply Prometheus Scrape Config') {
            when {
                branch 'main'
            }
            steps {
                sh """
                    kubectl create configmap prometheus-scrape-config \
                        --from-file=prometheus.yml=docker-compose/prometheus.yml \
                        --namespace ${MONITORING_NS} \
                        --dry-run=client -o yaml | kubectl apply -f -
                """
            }
        }

        stage('Import Grafana Dashboard') {
            when {
                branch 'main'
            }
            steps {
                sh """
                    kubectl create configmap ecommerce-grafana-dashboard \
                        --from-file=grafana-dashboard.json=monitoring/grafana-dashboard.json \
                        --namespace ${MONITORING_NS} \
                        --dry-run=client -o yaml \
                    | kubectl label --local -f - grafana_dashboard=1 --dry-run=client -o yaml \
                    | kubectl apply -f -
                """
            }
        }
    }

