                            message: "Deploy ecommerce-api build #${env.BUILD_NUMBER} to PRODUCTION?",
                            ok: 'Approve',
                            submitter: 'senior-devops,release-manager',
                            parameters: [
                                string(name: 'REASON', defaultValue: '', description: 'Reason for approval'),
                                choice(name: 'ENVIRONMENT', choices: ['prod-us-east-1'], description: 'Target environment')
                            ]
                        )
                        echo "Production deploy approved by: ${approver}"
                    }
                }
            }
        }

        stage('Helm Deploy to EKS (Production)') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'AWS-cred',
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    sh """
                        aws eks update-kubeconfig --name ${EKS_CLUSTER} --region ${AWS_REGION}
                        helm upgrade --install ecommerce-api ./helm/ecommerce-api \
