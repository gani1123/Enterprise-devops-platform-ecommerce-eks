{
  "id": null,
  "uid": "enterprise-ecommerce-jvm",
  "title": "Enterprise E-commerce - Tomcat JVM Dashboard",
  "tags": ["tomcat", "jvm", "ecommerce", "java"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(jvm_heap_memory_used_bytes, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "label": "Instance"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(tomcat_requestcount_total{instance=~\"$instance\"}[1m])",
          "legendFormat": "{{instance}} - {{protocol}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP Error Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(tomcat_errorcount_total{instance=~\"$instance\"}[1m])",
          "legendFormat": "{{instance}} errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "id": 3,
      "title": "Tomcat Active Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "tomcat_threadpool_currentthreadsbusy{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} - Busy"
        },
        {
          "expr": "tomcat_threadpool_currentthreadcount{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} - Total"
        },
        {
          "expr": "tomcat_threadpool_max_threads{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} - Max"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 4,
      "title": "JVM Heap Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "jvm_heap_memory_used_bytes{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} - Used"
        },
        {
          "expr": "jvm_heap_memory_committed_bytes{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} - Committed"
        },
        {
          "expr": "jvm_heap_memory_max_bytes{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} - Max"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 5,
      "title": "JVM GC Collection Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(jvm_gc_collection_count_total{instance=~\"$instance\"}[1m])",
          "legendFormat": "{{instance}} - {{gc}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 6,
      "title": "JVM Thread Count",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "jvm_threads_ThreadCount{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 200 }
          ]
        }}
      }
    },
    {
      "id": 7,
      "title": "Average Response Time (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(tomcat_processingtime_total{instance=~\"$instance\"}[1m]) / rate(tomcat_requestcount_total{instance=~\"$instance\"}[1m])",
          "legendFormat": "{{instance}} avg response ms"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 8,
      "title": "CPU Load",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "jvm_os_ProcessCpuLoad{instance=~\"$instance\"} * 100",
          "legendFormat": "{{instance}} Process CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Non-Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "jvm_nonheap_memory_used_bytes{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} - Non-Heap Used"
        },
        {
          "expr": "jvm_nonheap_memory_committed_bytes{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} - Non-Heap Committed"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    }
  ]
}
